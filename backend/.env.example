# Get a free key at https://openrouter.ai/keys — no credit card required.
# "openrouter/free" auto-routes across whichever :free models are currently
# available; set a specific model ID (e.g. a model from openrouter.ai/models
# with the Free price filter) if you want to pin one instead.
OPENROUTER_API_KEY=your_openrouter_api_key_here
